{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(rails_requests_total[$__rate_interval]))",
          "legendFormat": "{{ app }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (rate(rails_requests_total{status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{ app }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    },
    {
      "title": "p50 / p95 / p99 Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (app, le) (rate(rails_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{ app }} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (app, le) (rate(rails_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{ app }} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (app, le) (rate(rails_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{ app }} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5 }
        },
        "overrides": []
      }
    },
    {
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(rails_requests_total{app=~\"$app\"}[$__rate_interval]))",
          "legendFormat": "{{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      }
    },
    {
      "title": "Response Time by Controller",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (controller, le) (rate(rails_request_duration_seconds_bucket{app=~\"$app\"}[$__rate_interval]))))",
          "legendFormat": "{{ controller }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 5 }
        },
        "overrides": []
      }
    },
    {
      "title": "Puma — Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (puma_running_threads{app=~\"$app\"})",
          "legendFormat": "{{ app }} running"
        },
        {
          "expr": "sum by (app) (puma_max_threads{app=~\"$app\"})",
          "legendFormat": "{{ app }} max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "Puma — Backlog",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (puma_backlog{app=~\"$app\"})",
          "legendFormat": "{{ app }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      }
    },
    {
      "title": "Puma — Pool Capacity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (app) (puma_pool_capacity{app=~\"$app\"})",
          "legendFormat": "{{ app }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["rails", "hubcap"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "app",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(rails_requests_total, app)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Rails Overview",
  "uid": "hubcap-rails-overview"
}
