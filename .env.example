# =============================================================================
# Hubcap — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Domains — Caddy uses these for TLS certs and routing
# ---------------------------------------------------------------------------
SIGNOZ_DOMAIN=signoz.example.com
GLITCHTIP_DOMAIN=glitchtip.example.com
OTEL_DOMAIN=otel.example.com

# ---------------------------------------------------------------------------
# SigNoz
# ---------------------------------------------------------------------------
# Random secret used to sign JWT tokens for the SigNoz UI
# Generate with: openssl rand -hex 32
SIGNOZ_JWT_SECRET=change-me-to-a-random-string

# ---------------------------------------------------------------------------
# GlitchTip
# ---------------------------------------------------------------------------
GLITCHTIP_SECRET_KEY=change-me-to-a-random-string

# GlitchTip database
GLITCHTIP_DB_USER=glitchtip
GLITCHTIP_DB_PASSWORD=changeme
GLITCHTIP_DB_NAME=glitchtip

# Email (consolemail:// prints to stdout — replace with smtp:// for real email)
GLITCHTIP_FROM_EMAIL=noreply@example.com
GLITCHTIP_EMAIL_URL=consolemail://

# Registration — set both to true for initial setup, then switch to false
# ENABLE_REGISTRATION controls whether the register page works at all
# ENABLE_ORG_CREATION controls whether new users can create organizations
GLITCHTIP_ENABLE_REGISTRATION=true
GLITCHTIP_ENABLE_ORG_CREATION=true
